APP_NAME=PaperHermes
APP_ENV=development
API_PREFIX=/api

POSTGRES_DB=paperhermes
POSTGRES_USER=paperhermes
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://paperhermes:change-me@localhost:5432/paperhermes

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=paper_chunks
UPLOAD_DIR=uploads

# OpenAI-compatible provider. Keep the real key only in an untracked .env file.
LLM_PROVIDER=stub
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
LLM_API_STYLE=responses

# Keep fixed/balanced for a stable baseline. Set to linucb to enable online policy learning.
POLICY_NAME=fixed
POLICY_ALPHA=0.5
POLICY_EPSILON=0.1
POLICY_MIN_SAMPLES=1

EMBEDDING_PROVIDER=local
EMBEDDING_API_KEY=
EMBEDDING_MODEL=models/bge-small-zh-v1.5
EMBEDDING_DIM=384
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=2
EMBEDDING_MAX_LENGTH=1024

FEISHU_WEBHOOK_URL=
WECOM_WEBHOOK_URL=
